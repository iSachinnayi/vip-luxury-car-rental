# ═══════════════════════════════════════════════
#  VIP Luxury Car Rental — Environment Variables
#  ⚠️  NEVER commit real .env file to git!
#  Copy this to .env and fill in your values
# ═══════════════════════════════════════════════

# Site
NEXT_PUBLIC_SITE_URL=https://vipluxurycarrental.com
NEXT_PUBLIC_SITE_NAME=VIP Luxury Car Rental

# Contact
NEXT_PUBLIC_PHONE=+971501564849
NEXT_PUBLIC_EMAIL=booking@vipluxurycarrental.com
NEXT_PUBLIC_WHATSAPP=https://wa.me/971501564849

# Address
NEXT_PUBLIC_ADDRESS=Al Barsha Near Mall Of Emirates, Dubai

# API Keys (Optional - for future features)
# DEEPL_API_KEY=your_deepl_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

# Currency API (Frankfurter.dev - FREE, no key needed!)
NEXT_PUBLIC_CURRENCY_API=https://api.frankfurter.dev/v2

# Image Uploads Directory (override for production)
# If not set, defaults to: <project>/../server_data/images_full/var/www/.../uploads/
# Production: IMAGES_UPLOADS_DIR=/var/data/images/uploads
# IMAGES_UPLOADS_DIR=
